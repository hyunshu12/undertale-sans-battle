{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build dodge",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-lncurses"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "현재 .c 파일을 ncurses 링크해서 컴파일 (Cmd+Shift+B)"
        },
        {
            "label": "build & run dodge",
            "type": "shell",
            "command": "gcc -g \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}\" -lncurses && \"${fileDirname}/${fileBasenameNoExtension}\"",
            "group": "test",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "detail": "컴파일 후 통합 터미널에서 바로 실행 (ncurses 게임용)"
        }
    ]
}
